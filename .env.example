# Example environment variables for production (Render)
# Copy this to a local `.env` for development only. Never commit secrets to git.

# Core
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=maganacademy.onrender.com
SITE_URL=https://maganacademy.onrender.com
CSRF_TRUSTED_ORIGINS=https://maganacademy.onrender.com

# Database: set this in Render dashboard to your Neon/Postgres URL
# Example (NEON):
# postgresql://neondb_owner:password@host/elearning?sslmode=require&channel_binding=require
DATABASE_URL=

# Email (example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Payment gateways (set as needed)
WAAFIPAY_MERCHANT_ID=
WAAFIPAY_API_USER_ID=
WAAFIPAY_API_KEY=
WAAFIPAY_MODE=production

# Celery / Redis (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Static & media (when using S3 or other storage)
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
